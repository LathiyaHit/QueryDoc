# ─────────────────────────────────────────────
# App
# ─────────────────────────────────────────────
APP_ENV=development
SECRET_KEY=change-me-to-a-random-64-char-string
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# ─────────────────────────────────────────────
# Database
# ─────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://username:password@localhost:5432/voiceai
REDIS_URL=redis://localhost:6379/0

# ─────────────────────────────────────────────
# AI Services
# ─────────────────────────────────────────────
GROQ_API_KEY=gsk_...
DEEPGRAM_API_KEY=...
ELEVENLABS_API_KEY=...

# ─────────────────────────────────────────────
# Vector DB
# ─────────────────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=user_memories

# ─────────────────────────────────────────────
# Observability
# ─────────────────────────────────────────────
LANGFUSE_PUBLIC_KEY=...
LANGFUSE_SECRET_KEY=...
LANGFUSE_HOST=http://localhost:3000
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# ─────────────────────────────────────────────
# RAG
# ─────────────────────────────────────────────
RAG_QDRANT_COLLECTION=rag_documents
RAG_DOCS_DIR=data/rag_docs
RAG_CHUNK_SIZE=1000
RAG_CHUNK_OVERLAP=200
RAG_TOP_K=5
RAG_MIN_SCORE=0.2